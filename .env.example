# === Polymarket Bot Config ===
# Copie ce fichier en .env et remplis les valeurs

# Ta clé privée MetaMask (0x...) — NE JAMAIS PARTAGER
PRIVATE_KEY=0xTA_CLE_PRIVEE_ICI

# Ton adresse proxy Polymarket (visible dans profil -> adresse)
FUNDER_ADDRESS=0xTON_ADRESSE_PROXY_ICI

# Type de signature (0=EOA/MetaMask, 1=POLY_PROXY, 2=GNOSIS_SAFE)
SIGNATURE_TYPE=2

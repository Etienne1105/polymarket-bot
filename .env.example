# === Polymarket Bot Config ===
# Ces secrets sont maintenant stockes dans le Keychain macOS.
# Lance "setup keychain" dans le bot pour les configurer.
#
# Si tu preferes utiliser un .env (moins securise), copie ce fichier :
#   cp .env.example .env
# Puis remplis les valeurs.

# Ta cle privee MetaMask (0x + 64 hex) — NE JAMAIS PARTAGER
PRIVATE_KEY=0xTA_CLE_PRIVEE_ICI

# Ton adresse publique MetaMask (0x + 40 hex)
FUNDER_ADDRESS=0xTON_ADRESSE_PROXY_ICI

# Type de signature (0=EOA/MetaMask, 1=POLY_PROXY, 2=GNOSIS_SAFE)
SIGNATURE_TYPE=2

# Cle API Anthropic (pour les avis Claude)
ANTHROPIC_API_KEY=sk-ant-TA_CLE_ICI
